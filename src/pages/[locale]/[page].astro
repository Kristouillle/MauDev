---
import About from '../../components/About.astro';
import Navbar from '../../components/Navbar.astro';
import ProjectsGrid from '../../components/ProjectsGrid.astro';
import { siteContent, type Locale } from '../../data/siteContent';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageLayout from '../../layouts/PageLayout.astro';

type PageKey = 'about' | 'projects' | 'contact';

export function getStaticPaths() {
  const locales: Locale[] = ['fr', 'en'];
  const pageKeys: PageKey[] = ['about', 'projects', 'contact'];
  return locales.flatMap((locale) => pageKeys.map((page) => ({ params: { locale, page } })));
}

const { locale, page } = Astro.params as { locale: Locale; page: PageKey };
const content = siteContent[locale];

const pageTitleByLocale: Record<Locale, Record<PageKey, string>> = {
  fr: {
    about: 'Comment nous operons | MauDev',
    projects: 'Projets | MauDev',
    contact: 'Contact | MauDev'
  },
  en: {
    about: 'How we do it | MauDev',
    projects: 'Projects | MauDev',
    contact: 'Contact | MauDev'
  }
};
---

{
  page === 'about' || page === 'projects' ? (
    <PageLayout locale={locale} title={pageTitleByLocale[locale][page]}>
      <Navbar locale={locale} theme="light" />
      {
        page === 'about' ? (
          <About locale={locale} />
        ) : (
          <section class="content-block content-block--projects">
            <ProjectsGrid locale={locale} />
          </section>
        )
      }
    </PageLayout>
  ) : (
    <BaseLayout locale={locale} title={pageTitleByLocale[locale][page]}>
      {
        page === 'contact' && (
          <section class="content-block reveal">
            <h1>{content.contact.title}</h1>
            <p>{content.contact.intro}</p>
            <ul class="contact-list">
              <li><strong>{content.contact.emailLabel}:</strong> info@example.com</li>
              <li><strong>{content.contact.phoneLabel}:</strong> +1 555 010 020</li>
            </ul>
          </section>
        )
      }
    </BaseLayout>
  )
}
