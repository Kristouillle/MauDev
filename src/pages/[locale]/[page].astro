---
import About from '../../components/About.astro';
import Navbar from '../../components/Navbar.astro';
import ProjectsGrid from '../../components/ProjectsGrid.astro';
import { isLocale, type Locale } from '../../data/siteContent';
import PageLayout from '../../layouts/PageLayout.astro';

type PageKey = 'about' | 'projects';

export function getStaticPaths() {
  const locales: Locale[] = ['fr', 'en'];
  const pageKeys: PageKey[] = ['about', 'projects'];
  return locales.flatMap((locale) => pageKeys.map((page) => ({ params: { locale, page } })));
}

const locale: Locale = isLocale(Astro.params.locale)
  ? Astro.params.locale
  : 'en';
const page: PageKey = Astro.params.page === 'about' || Astro.params.page === 'projects'
  ? Astro.params.page
  : 'about';

const pageTitleByLocale: Record<Locale, Record<PageKey, string>> = {
  fr: {
    about: 'Notre modèle intégré | MauDev',
    projects: 'Projets | MauDev'
  },
  en: {
    about: 'Our integrated model | MauDev',
    projects: 'Projects | MauDev'
  }
};
---

<PageLayout locale={locale} title={pageTitleByLocale[locale][page]}>
  <Navbar locale={locale} />
  {
    page === 'about' ? (
      <About locale={locale} />
    ) : (
      <section class="content-block content-block--projects">
        <ProjectsGrid locale={locale} />
      </section>
    )
  }
</PageLayout>
