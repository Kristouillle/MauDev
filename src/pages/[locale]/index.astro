---
import CookieBanner from '../../components/CookieBanner.astro';
import Home from '../../components/Home.astro';
import Navbar from '../../components/Navbar.astro';
import { isLocale, type Locale } from '../../data/siteContent';
import PageLayout from '../../layouts/PageLayout.astro';

export function getStaticPaths() {
  return [{ params: { locale: 'fr' } }, { params: { locale: 'en' } }];
}


const locale: Locale = isLocale(Astro.params.locale)
  ? Astro.params.locale
  : 'en';
const pageTitle = locale === 'fr'
  ? 'Développement immobilier et construction intégrée | MauDev'
  : 'Real Estate Development & Integrated Construction | MauDev';
---

<PageLayout locale={locale} title={pageTitle}>
  <Navbar locale={locale} overlay={true} />
  <Home locale={locale} />
  <CookieBanner locale={locale} />
</PageLayout>

