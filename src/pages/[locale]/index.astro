---

import CookieBanner from '../../components/CookieBanner.astro';
import Home from '../../components/Home.astro';
import Navbar from '../../components/Navbar.astro';
import PageLayout from '../../layouts/PageLayout.astro';

import { isLocale, siteContent, type Locale } from '../../data/siteContent';

export function getStaticPaths() {
  return [{ params: { locale: 'fr' } }, { params: { locale: 'en' } }];
}


const { locale } = Astro.params as { locale: Locale };
const pageTitle = locale === 'fr' ? 'Presentation | MauDev' : 'Overview | MauDev';
---

<PageLayout locale={locale} title={pageTitle}>
  <Navbar locale={locale} theme="dark" overlay={true} />
  <Home locale={locale} />
  <CookieBanner locale={locale} />
</PageLayout>

