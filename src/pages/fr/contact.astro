---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { siteContent } from '../../data/siteContent';

const content = siteContent.fr.contact;
---

<BaseLayout locale="fr" title="Contact | MauDev">
  <section class="content-block reveal">
    <h1>{content.title}</h1>
    <p>{content.intro}</p>
    <ul class="contact-list">
      <li><strong>{content.emailLabel}:</strong> info@example.com</li>
      <li><strong>{content.phoneLabel}:</strong> +1 555 010 020</li>
    </ul>
  </section>
</BaseLayout>
