---
import { pageContent } from '../data/pageContent';
import type { Locale } from '../data/siteContent';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const text = pageContent[locale].about;
const capitalCounterTarget = 64;
---

<section class="about" data-node-id="136:428">
  <section class="width about__title-row" data-node-id="141:133">
    <h1 class="about__title">{text.title}</h1>
    <p class="about__intro reveal-in-up"
          style="--reveal-delay: 250ms;">{text.intro}</p>
    <div class="about__capital reveal-in-up"
        style="--reveal-delay: 500ms;">
      <p>{text.capitalLabel}</p>
      <strong
        class="about__capital-value"
        data-counter-target={String(capitalCounterTarget)}
      >
        0m$
      </strong>
    </div>
  </section>

  <section class="about__formula" data-node-id="138:152">
    <h2 class="about__formula-heading">{text.formulaHeading}</h2>
    {text.formulaSteps.map((step, index) => (
      <article
        class:list={[
          'formula-card',
          index % 2 === 1 && 'formula-card--flip',
          `formula-card--tone-${(index % 3) + 1}`
        ]}
      >
        <div class="width formula-card__inner">
          <div class="formula-card__media" aria-hidden="true"></div>
          <div
            class="formula-card__copy reveal-on-scroll"
            style={`--reveal-delay:${140 + index * 120}ms;`}
          >
            <p class="formula-card__label">{step.label}</p>
            <p>{step.body}</p>
          </div>
        </div>
      </article>
    ))}
  </section>

  <section class="width about__values" data-node-id="141:132">
    <h2>{text.valuesHeading}</h2>
    <div class="faq-list">
      {text.values.map((value, index) => (
        <details class="faq-item">
          <summary class="faq-summary">
            <span>{index + 1}. {value.title}</span>
          </summary>
          <div class="faq-answer">
            <p>{value.body}</p>
          </div>
        </details>
      ))}
    </div>
  </section>

  <section class="about__team" data-node-id="141:131">
    <div class="width about__team-grid">
      <div class="about__team-image" aria-hidden="true"></div>
      <div>
        <h2>{text.teamTitle}</h2>
        <p>{text.teamBody}</p>
      </div>
    </div>
  </section>
</section>

<script is:inline>
  (() => {
    const revealCards = Array.from(document.querySelectorAll('.about__formula .reveal-on-scroll'));
    const revealElement = (el) => el.classList.add('is-visible');

    if (revealCards.length) {
      if (!('IntersectionObserver' in window)) {
        revealCards.forEach(revealElement);
      } else {
        const revealObserver = new IntersectionObserver(
          (entries, obs) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;
              revealElement(entry.target);
              obs.unobserve(entry.target);
            });
          },
          {
            threshold: 0.2,
            rootMargin: '0px 0px -10% 0px'
          }
        );

        revealCards.forEach((card) => revealObserver.observe(card));
      }
    }

    const counter = document.querySelector('.about__capital-value[data-counter-target]');
    if (!counter) return;

    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const revealContainer = counter.closest('.about__capital');
    const target = Number(counter.dataset.counterTarget ?? 0);
    const duration = 750;
    const formatValue = (value) => `${Math.round(value)}m$`;
    counter.textContent = formatValue(0);

    const toMilliseconds = (timeValue) => {
      const raw = (timeValue ?? '').trim();
      if (!raw) return 0;
      if (raw.endsWith('ms')) return Number.parseFloat(raw);
      if (raw.endsWith('s')) return Number.parseFloat(raw) * 1000;
      return Number.parseFloat(raw) || 0;
    };

    const setFinalValue = () => {
      counter.textContent = formatValue(target);
      counter.dataset.counterDone = 'true';
    };

    const animateCounter = () => {
      if (counter.dataset.counterDone === 'true') return;

      const start = performance.now();

      const tick = (now) => {
        const progress = Math.min((now - start) / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        counter.textContent = formatValue(target * eased);

        if (progress < 1) {
          requestAnimationFrame(tick);
          return;
        }

        counter.dataset.counterDone = 'true';
      };

      requestAnimationFrame(tick);
    };

    const startWithReveal = () => {
      if (!revealContainer) {
        animateCounter();
        return;
      }

      let hasStarted = false;
      const startOnce = () => {
        if (hasStarted) return;
        hasStarted = true;
        animateCounter();
      };

      const computed = window.getComputedStyle(revealContainer);
      const delayValue = (computed.animationDelay || '0ms').split(',')[0];
      const fallbackDelay = toMilliseconds(delayValue) + 20;

      revealContainer.addEventListener(
        'animationstart',
        (event) => {
          if (event.target !== revealContainer) return;
          startOnce();
        },
        { once: true }
      );

      window.setTimeout(startOnce, fallbackDelay);
    };

    if (prefersReducedMotion) {
      setFinalValue();
      return;
    }

    if (!('IntersectionObserver' in window)) {
      startWithReveal();
      return;
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          startWithReveal();
          observer.unobserve(counter);
        });
      },
      { threshold: 0.5 }
    );

    observer.observe(counter);
  })();
</script>
