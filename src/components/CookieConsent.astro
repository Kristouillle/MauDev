---
import { siteContent, type Locale } from '../data/siteContent';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const text = siteContent[locale].cookieBanner;
---

<section class="cookie-banner" data-cookie-banner hidden>
  <p class="cookie-banner__title">{text.title}</p>
  <p>{text.description}</p>
  <div class="cookie-banner__actions">
    <button type="button" class="button" data-consent-action="accept">{text.accept}</button>
    <button type="button" class="button button--secondary" data-consent-action="reject">{text.reject}</button>
  </div>
</section>

<script src="/scripts/cookie-consent.js"></script>
