---
import { pageContent } from '../data/pageContent';
import { isLocale, type Locale } from '../data/siteContent';

interface Props {
  locale?: Locale;
  overlay?: boolean;
}

const { overlay = false } = Astro.props as Props;
const locale: Locale = isLocale(Astro.props.locale)
  ? Astro.props.locale
  : Astro.url.pathname.startsWith('/fr')
    ? 'fr'
    : 'en';

const text = pageContent[locale]?.nav ?? pageContent.en.nav;
const alternateLocale = locale === 'fr' ? 'en' : 'fr';
const alternatePath = /^\/(fr|en)(?=\/|$)/.test(Astro.url.pathname)
  ? Astro.url.pathname.replace(/^\/(fr|en)(?=\/|$)/, `/${alternateLocale}`)
  : `/${alternateLocale}`;

const links = [
  { href: `/${locale}/projects`, label: text.projects },
  { href: `/${locale}/about`, label: text.about }
];
---

<header class:list={['nav', 'nav--light', overlay && 'nav--overlay']}>
  <div class="width nav__inner">
    <a class="nav__brand" href={`/${locale}`}>MauDev</a>
    <nav>
      <ul class="nav__list">
        {links.map((link) => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
        <li><a class="nav__lang" href={alternatePath}>{alternateLocale.toUpperCase()}</a></li>
      </ul>
    </nav>
  </div>
</header>
