---
import { pageContent } from '../data/pageContent';
import type { Locale } from '../data/siteContent';

interface Props {
  locale: Locale;
  theme?: 'dark' | 'light';
  overlay?: boolean;
}

const { locale, theme = 'light', overlay = false } = Astro.props;
const text = pageContent[locale].nav;
const alternateLocale = locale === 'fr' ? 'en' : 'fr';
const alternatePath = Astro.url.pathname.replace(`/${locale}`, `/${alternateLocale}`) || `/${alternateLocale}`;

const links = [
  { href: `/${locale}/projects`, label: text.projects },
  { href: `/${locale}/about`, label: text.about }
];
---

<header class:list={['nav', `nav--${theme}`, overlay && 'nav--overlay']}>
  <div class="width nav__inner">
    <a class="nav__brand" href={`/${locale}`}>MauDev</a>
    <nav>
      <ul class="nav__list">
        {links.map((link) => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
        <li><a class="nav__lang" href={alternatePath}>{alternateLocale.toUpperCase()}</a></li>
      </ul>
    </nav>
  </div>
</header>
