---
import { pageContent } from '../data/pageContent';
import { projects, type Project } from '../data/projects';
import { isLocale, type Locale } from '../data/siteContent';

interface Props {
  locale?: Locale;
}

const locale: Locale = isLocale(Astro.props.locale)
  ? Astro.props.locale
  : Astro.url.pathname.startsWith('/fr')
    ? 'fr'
    : 'en';

const text = pageContent[locale]?.home ?? pageContent.en.home;
const tickerItems = [...text.tickerItems, ...text.tickerItems];
const featuredProjects = text.featuredProjectIds
  .map((id) => projects.find((project) => project.id === id))
  .filter((project): project is Project => Boolean(project))
  .map((project) => ({
    id: project.id,
    title: project.title[locale],
    subtitle: project.city[locale],
    description: project.detailsBody[locale],
    image: project.gallery[0] ?? ''
  }))
  .filter((project) => project.image);
---

<section class="home">
  <section class="hero" data-node-id="71:16">
    <video
      class="hero__bg"
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      aria-hidden="true"
      disablepictureinpicture
      disableremoteplayback
    >
      <source src="/videos/Rook_bird.mov" />
    </video>
    <div class="hero__shade"></div>

    <div class="width hero__menu" data-node-id="71:29">
      <div class="hero__links">
        <a
          href={`/${locale}/about`}
          class="link-underline reveal-in-up"
          style="--reveal-delay: 110ms;"
        >
          {text.links.investing}
        </a>
        <a
          href={`/${locale}/projects`}
          class="link-underline reveal-in-up"
          style="--reveal-delay: 220ms;"
        >
          {text.links.projects}
        </a>
      </div>
      <p>{text.heroDescription}</p>
    </div>

    <div class="hero__ticker" aria-label="Messages defilants">
      <div class="hero__ticker-track">
      {tickerItems.map((item) => (
          <span class="hero__ticker-item">{item}</span>
      ))}
      </div>
    </div>
  </section>

  <section class="home-green" data-node-id="71:67">
    <div class="home-green__inner">
      <h2>{text.institutionalTitle}</h2>
      <div class="home-steps">
        {text.steps.map((step, index) => (
          <article class="step-card reveal-on-scroll" style={`--reveal-delay:${220 + index * 120}ms;`}>
            <h3>
              <span class="step-icon" style={`--mask:url('${step.iconMask}')`}></span>
              <span class="step-card__title">{index + 1}. {step.title}</span>
            </h3>
            <p>{step.body}</p>
          </article>
        ))}
      </div>
      <a href={`/${locale}/contact`} class="link-underline">{text.links.howToInvest}</a>
    </div>
  </section>

  <section class="home-projects" data-node-id="83:326">
    <div class="home-projects__inner">
      <p class="home-projects__lead">{text.trustStatement}</p>
      <div class="project-stack">
        {featuredProjects.map((project, index) => (
          <article
            class="project-spotlight"
            data-node-id="83:362"
            style={`--stack-z:${index + 1}; --stack-shift:${index * 1.35}rem;`}
          >
            <img src={project.image} alt={project.title} />
            <div class="project-spotlight__content">
              <h3>{project.title}</h3>
              <h4>{project.subtitle}</h4>
              <p>{project.description}</p>
              <a href={`/${locale}/projects/${project.id}`} class="link-underline">{text.projectCta}</a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</section>

<script is:inline>
  (() => {
    const cards = Array.from(document.querySelectorAll('.home-green .reveal-on-scroll'));
    if (!cards.length) return;

    const reveal = (el) => el.classList.add('is-visible');

    if (!('IntersectionObserver' in window)) {
      cards.forEach(reveal);
      return;
    }

    const observer = new IntersectionObserver(
      (entries, obs) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          reveal(entry.target);
          obs.unobserve(entry.target);
        });
      },
      {
        threshold: 0.18,
        rootMargin: '0px 0px -12% 0px'
      }
    );

    cards.forEach((card) => observer.observe(card));
  })();
</script>
