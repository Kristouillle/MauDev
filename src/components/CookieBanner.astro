---
import { siteContent, type Locale } from '../data/siteContent';
import CookieSetting from './CookieSetting.astro';
import consentScriptUrl from '../scripts/cookie-consent.js?url';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const text = siteContent[locale].cookieBanner;
---

<section class="cookie-banner" data-cookie-banner hidden>
  <p class="cookie-banner__title">{text.title}</p>
  <p>{text.description}</p>
  <CookieSetting  locale={locale}/>
</section>

<script type="module" src={consentScriptUrl}></script>
<script type="module" src="/scripts/init-consent.js"></script>
